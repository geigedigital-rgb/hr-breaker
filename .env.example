# Required: key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-api-key-here

# Models (if you get 500 / API key errors, try gemini-2.5-flash)
GEMINI_PRO_MODEL=gemini-3-pro-preview
GEMINI_FLASH_MODEL=gemini-3-flash-preview
GEMINI_THINKING_BUDGET=8192

# Logging
LOG_LEVEL=WARNING
LOG_LEVEL_GENERAL=WARNING

# Mode (parallel checks)
HR_BREAKER_FAST_MODE=true

# Ускорение: меньше итераций = быстрее (по умолчанию 5)
MAX_ITERATIONS=2

# Scraper settings
SCRAPER_HTTPX_TIMEOUT=15
SCRAPER_WAYBACK_TIMEOUT=10
SCRAPER_PLAYWRIGHT_TIMEOUT=60000
SCRAPER_USE_STEALTH=true
SCRAPER_PLAYWRIGHT_LOCALE=en-US
SCRAPER_HTTPX_MAX_RETRIES=3
SCRAPER_WAYBACK_MAX_AGE_DAYS=30
SCRAPER_MIN_TEXT_LENGTH=200

# Adzuna (free job search API, e.g. Germany). Get keys at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Apify (StepStone etc.): optional paid scrapers. Get token at https://apify.com/
APIFY_TOKEN=
SCRAPER_USE_APIFY=true
SCRAPER_APIFY_ACTOR_ID=fatihtahta/stepstone-scraper-fast-reliable-4-1k
SCRAPER_APIFY_DOMAINS=stepstone.de,stepstone.at,stepstone.be,stepstone.nl
# StepStone: Playwright tried first (one page, ~15–60s); Apify fallback, timeout in seconds
SCRAPER_APIFY_TIMEOUT=60

# Database (optional): Postgres for history and auth. When set, login is required and data is per-user.
# Example Neon: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Install: uv pip install 'hr-breaker[db]'
DATABASE_URL=

# Auth (required when DATABASE_URL is set)
JWT_SECRET=your-secret-at-least-32-chars-long
# Google OAuth for "Login with Google". Create OAuth 2.0 credentials in Google Cloud Console.
# Authorized redirect URI: http://localhost:5173/auth/callback (and your production URL)
# Один OAuth-клиент в Google Console; в нём укажите оба redirect URI:
#   http://localhost:5173/auth/callback
#   https://hr-breaker-production.up.railway.app/auth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Локально: фронт на 5173. На деплое (Railway): URL вашего приложения (без слэша в конце)
# Локально: FRONTEND_URL=http://localhost:5173
# Деплой:   FRONTEND_URL=https://hr-breaker-production.up.railway.app
FRONTEND_URL=http://localhost:5173
# Письма (Resend): абсолютные URL картинок и CTA. PitchCV: приложение на https://my.pitchcv.app (там же /public).
# Если пусто — используется FRONTEND_URL.
EMAIL_PUBLIC_BASE_URL=

# Filter thresholds
FILTER_HALLUCINATION_THRESHOLD=0.9
FILTER_KEYWORD_THRESHOLD=0.25
FILTER_LLM_THRESHOLD=0.7
FILTER_VECTOR_THRESHOLD=0.4
FILTER_AI_GENERATED_THRESHOLD=0.4

# Resume length limits
RESUME_MAX_CHARS=4500
RESUME_MAX_WORDS=520
RESUME_PAGE2_OVERFLOW_CHARS=1000

# Keyword matcher
KEYWORD_TFIDF_MAX_FEATURES=200
KEYWORD_TFIDF_CUTOFF=0.1
KEYWORD_MAX_MISSING_DISPLAY=10

# Sentence transformer (vector similarity)
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# Agent limits
AGENT_NAME_EXTRACTOR_CHARS=2000

# Stripe (payments). Dashboard: https://dashboard.stripe.com/
# Keys: Developers → API keys (Publishable key + Secret key)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook: Developers → Webhooks → Add endpoint → https://your-api.com/api/payments/webhook
#   Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring $29/month (subscription). Used for both "monthly" and "trial" (trial adds 7 days + fee below).
STRIPE_PRICE_MONTHLY_ID=price_...
# One-time $2.99 — required for trial Checkout to show "due today". Stripe → Products → add Price → One time $2.99 USD.
STRIPE_PRICE_TRIAL_ID=price_...

# Landing (pitchcv.app): public trial analysis. Backend at my.pitchcv.app
# Apex и www — разные Origin в браузере; в api.py недостающий из пары pitchcv.app/www добавляется автоматически.
LANDING_ALLOWED_ORIGINS=https://pitchcv.app,https://www.pitchcv.app
LANDING_RATE_LIMIT_HOURS=24
LANDING_MAX_RESUME_CHARS=50000
LANDING_MAX_JOB_URL_LEN=2048
# TTL токена «сохранить и перейти на логин» (секунды). По умолчанию 15 мин.
LANDING_PENDING_TTL_SECONDS=900

# Admin: дополнительные email (через запятую), тот же доступ что у ADMIN_EMAIL
# ADMIN_EMAIL=...
# ADMIN_EMAILS=editor1@example.com,editor2@example.com

# Resend (https://resend.com/) — win-back queue + admin manual segment send. Never commit real keys.
# RESEND_API_KEY: пусто в репо; на проде только в Railway Variables (или в локальном .env, не в git).
RESEND_API_KEY=
# Verified sender, e.g. PitchCV <news@yourdomain.com> (must match Resend domain)
RESEND_FROM=
# Optional: support inbox (replies go here; looks less like bulk-only noreply).
RESEND_REPLY_TO=
RESEND_WINBACK_SUBJECT=Your resume is ready
# Optional fallback: Resend template id if not set in admin DB (Email → Automation & send).
# Prefer saving ids in Postgres via admin UI so Railway only needs secrets.
RESEND_TEMPLATE_REMINDER_NO_DOWNLOAD=
RESEND_TEMPLATE_SHORT_NUDGE=

# --- Railway (Variables на сервисе с API / uvicorn) — отправка писем через Resend ---
# Обязательно:
#   RESEND_API_KEY=re_...                    # Resend → API Keys → создать ключ
#   RESEND_FROM=PitchCV <hello@yourdomain.com>  # отправитель; домен должен быть Verified в Resend → Domains
# Рекомендуется для PitchCV (ссылки/картинки/отписка в письме на том же хосте, что и /api):
#   EMAIL_PUBLIC_BASE_URL=https://my.pitchcv.app
# Уже должны быть для приложения (логин, отписка JWT):
#   JWT_SECRET=...
#   DATABASE_URL=...
#   FRONTEND_URL=https://...                 # редиректы; если EMAIL_PUBLIC_BASE_URL пуст — письма берут базу отсюда
#   Важно на проде (Railway и т.д.): задайте FRONTEND_URL явно. Если не задать, в коде остаётся дефолт
#   http://localhost:5173 — в админке Config и в письмах Resend будут localhost-ссылки.
# Опционально:
#   RESEND_REPLY_TO=support@yourdomain.com
#   RESEND_WINBACK_SUBJECT=Your resume is ready
#   RESEND_TEMPLATE_* — fallback, если в админке (Email → Automation & send) не заполнены id шаблонов в БД
# Очередь win-back: периодически вызывать POST /api/admin/email/queue/process (cron или вручную в админке).
# Stagger-кампания (после Enroll / snapshot): POST /api/admin/email/stagger-campaign/process с admin-авторизацией — один due-отправитель за вызов; интервалы между письмами задаёт run_at в БД (3–8 мин), не «пачка» за один клик.

# --- Сборка фронта (Vite): положите в frontend/.env или передайте при build ---
# Превью писем в админке: те же URL картинок, что в проде (иначе берётся window.location.origin).
# VITE_EMAIL_ASSET_ORIGIN=https://my.pitchcv.app

# Лимиты POST /api/reviews (лендинг): за скользящий час по IP и за сутки по email
REVIEWS_RATE_LIMIT_IP_PER_HOUR=10
REVIEWS_RATE_LIMIT_EMAIL_PER_DAY=3
